# ==========================================
# BuildEstate Backend Environment Variables
# ==========================================
# Copy this file to .env (or .env.local) and fill in your actual values
# For security, never commit .env files to version control


# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development
BACKEND_URL="http://localhost:4000"


# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB Connection String
MONGO_URI="mongodb+srv://Dubai:ab1ab2ab3@cluster0.j3f6t6e.mongodb.net/realEstate"


# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# Generate a strong random string for JWT (use: openssl rand -base64 32)
JWT_SECRET="your_super_secure_jwt_secret_here_make_it_long_and_random"


# ===========================================
# EMAIL CONFIGURATION (Required for user notifications)
# ===========================================
# Option 1: Brevo (SendinBlue) SMTP (Recommended - Free tier available)
# Sign up at https://www.brevo.com/
SMTP_USER="your_brevo_smtp_login"
SMTP_PASS="your_brevo_smtp_password"
EMAIL="your_sender_email@domain.com"
EMAIL_USER="your_sender_email@domain.com"
BREVO_API_KEY="your_brevo_api_key"

# Option 2: Gmail SMTP (Alternative)
# Enable 2FA and generate App Password at https://myaccount.google.com/apppasswords
# SMTP_USER="your_email@gmail.com"
# SMTP_PASS="your_gmail_app_password"
# EMAIL="your_email@gmail.com"

# Admin Account Credentials (Change these!)
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="admin@987"


# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# URL where your frontend is deployed
# Local: http://localhost:5173
# Vercel: https://your-project.vercel.app
WEBSITE_URL="http://localhost:5173"

# CORS allowlist (used by backend/server.js)
# Primary frontend URL
FRONTEND_URL="http://localhost:5173"
# Primary admin URL
ADMIN_URL="http://localhost:5174"
# Optional comma-separated local origins
LOCAL_URLS="http://localhost:5173,http://localhost:5174,http://localhost:4000"
# Optional extra origins (comma-separated)
EXTRA_ALLOWED_ORIGINS=""


IMAGEKIT_PUBLIC_KEY="public_your_imagekit_public_key"
IMAGEKIT_PRIVATE_KEY="private_your_imagekit_private_key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"


FIRECRAWL_API_KEY="fc-your_firecrawl_api_key_here"


# ===========================================
# OPTIONAL CONFIGURATIONS
# ===========================================
# Rate limiting (requests per hour)
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000

# Session settings
SESSION_TIMEOUT_MINUTES=60

# File upload limits
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PROPERTY=10